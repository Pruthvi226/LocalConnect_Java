# ProxiSense Frontend Environment Configuration Template
# Copy this file to .env and update the values

# Backend API URL (without trailing slash)
# Production Example: https://api.proxisense.com
REACT_APP_API_URL=http://localhost:8080/api

# Realtime WebSocket URL (without trailing slash)
# Production Example: https://api.proxisense.com/ws
REACT_APP_WS_URL=http://localhost:8080/ws

# Google Maps API Key
# Required for Nearby Services Map and Location Search
# Ensure the key is restricted to your domain in Google Cloud Console
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Razorpay Key ID
# Required for frontend payment initialization
# Production Example: rzp_live_xxxxxxxxxxxxxx
REACT_APP_RAZORPAY_KEY_ID=your_razorpay_key_id_here
